{
	"name": "@trenlok/vscode-toolbox",
	"type": "module",
	"version": "1.6.1",
	"private": true,
	"description": "A lightweight toolbox for Visual Studio Code",
	"author": "TrenLok",
	"license": "MIT",
	"engines": {
		"node": ">=24.16.0"
	},
	"scripts": {
		"dev": "nuxt dev --public",
		"generate": "nuxt generate",
		"preinstall": "npx only-allow pnpm",
		"postinstall": "nuxt prepare",
		"prepare": "pnpm run hooks:install",
		"bump": "bumpp",
		"typecheck": "nuxt typecheck",
		"tauri": "tauri",
		"tauri:dev": "node scripts/tauri-test.mjs dev",
		"tauri:build": "tauri build",
		"tauri:build:test": "node scripts/tauri-test.mjs",
		"tauri:build:debug": "tauri build --debug",
		"fmt:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
		"fmt:js": "eslint . --cache --fix",
		"fmt:styles": "stylelint \"**/*.{scss,vue}\" --cache --allow-empty-input --fix",
		"lint:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
		"lint:js": "eslint . --cache",
		"lint:styles": "stylelint \"**/*.{scss,vue}\" --cache --allow-empty-input",
		"lint": "pnpm run lint:rs && pnpm run lint:js && pnpm run lint:styles",
		"format": "pnpm run fmt:rs && pnpm run fmt:js && pnpm run fmt:styles",
		"analyze:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
		"hooks:install": "pnpm exec simple-git-hooks"
	},
	"dependencies": {
		"@pinia/nuxt": "^0.11.3",
		"@rhapsodic/bem-classnames": "^2.1.0",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-autostart": "~2.5.1",
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-fs": "^2.5.1",
		"@tauri-apps/plugin-log": "~2.8.0",
		"@tauri-apps/plugin-notification": "^2.3.3",
		"@tauri-apps/plugin-opener": "~2.5.4",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "~2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-store": "^2.4.3",
		"@tauri-apps/plugin-updater": "~2.10.1",
		"nuxt": "4.4.6",
		"perfect-scrollbar": "^1.5.6",
		"pinia": "^3.0.4",
		"vue": "^3.5.35",
		"vue-final-modal": "^4.5.5",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@rhapsodic/eslint-config": "^1.0.5",
		"@rhapsodic/stylelint-config": "^1.0.1",
		"@tauri-apps/cli": "^2.11.2",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"bumpp": "^11.1.0",
		"eslint": "^10.4.1",
		"eslint-plugin-vuejs-accessibility": "^2.5.0",
		"nuxt3-notifications": "^1.4.0",
		"postcss-html": "^1.8.1",
		"postcss-media-minmax": "^5.0.0",
		"postcss-scss": "^4.0.9",
		"sass-embedded": "^1.100.0",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^17.12.0",
		"typescript": "^6.0.3",
		"vue-tsc": "^3.3.3"
	},
	"simple-git-hooks": {
		"commit-msg": "pnpm exec commitlint --edit",
		"pre-commit": "pnpm run lint"
	},
	"packageManager": "pnpm@11.5.1"
}
