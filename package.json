{
	"name": "@trenlok/vscode-toolbox",
	"type": "module",
	"version": "1.1.0",
	"private": true,
	"description": "A lightweight toolbox for Visual Studio Code",
	"author": "TrenLok",
	"license": "MIT",
	"engines": {
		"node": ">=24.14.1"
	},
	"scripts": {
		"dev": "nuxt dev --public",
		"generate": "nuxt generate",
		"preinstall": "npx only-allow pnpm",
		"postinstall": "nuxt prepare",
		"prepare": "pnpm run hooks:install",
		"bump": "bumpp",
		"typecheck": "nuxt typecheck",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"tauri:build:debug": "tauri build --debug",
		"fmt:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
		"fmt:js": "eslint . --cache --fix",
		"fmt:styles": "stylelint \"**/*.{scss,vue}\" --cache --allow-empty-input --fix",
		"lint:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
		"lint:js": "eslint . --cache",
		"lint:styles": "stylelint \"**/*.{scss,vue}\" --cache --allow-empty-input",
		"lint": "pnpm run lint:rs && pnpm run lint:js && pnpm run lint:styles",
		"format": "pnpm run fmt:rs && pnpm run fmt:js && pnpm run fmt:styles",
		"analyze:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
		"hooks:install": "pnpm exec simple-git-hooks"
	},
	"dependencies": {
		"@pinia/nuxt": "^0.11.3",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-autostart": "~2.5.1",
		"@tauri-apps/plugin-dialog": "~2.6.0",
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-log": "~2.8.0",
		"@tauri-apps/plugin-notification": "^2.3.3",
		"@tauri-apps/plugin-opener": "~2.5.3",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "~2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-store": "^2.4.2",
		"@tauri-apps/plugin-updater": "~2.10.0",
		"@trenlok/bem-modifier-classes": "^1.0.2",
		"nuxt": "^4.4.2",
		"pathe": "^2.0.3",
		"perfect-scrollbar": "^1.5.6",
		"pinia": "^3.0.4",
		"ufo": "^1.6.3",
		"vue": "^3.5.31",
		"vue-final-modal": "^4.5.5",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@rhapsodic/eslint-config": "^1.0.4",
		"@stylistic/stylelint-config": "^5.0.0",
		"@tauri-apps/cli": "^2.10.1",
		"@vueuse/core": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"bumpp": "^11.0.1",
		"eslint": "^10.1.0",
		"eslint-plugin-vuejs-accessibility": "^2.5.0",
		"postcss-html": "^1.8.1",
		"postcss-media-minmax": "^5.0.0",
		"postcss-scss": "^4.0.9",
		"sass-embedded": "^1.98.0",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^17.6.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^3.0.0",
		"stylelint-high-performance-animation": "^2.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^6.0.2",
		"vue-tsc": "^3.2.6"
	},
	"simple-git-hooks": {
		"commit-msg": "pnpm exec commitlint --edit",
		"pre-commit": "pnpm run lint"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
