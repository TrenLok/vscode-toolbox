{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Capabilities for the app window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-always-on-top",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-open",
    "os:allow-family",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-locale",
    "notification:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/.vscode-shared/sharedStorage" },
        { "path": "$HOME/.vscode-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/Code/User/globalStorage" },
        { "path": "$CONFIG/Code/User/globalStorage/state.vscdb" },
        { "path": "$HOME/.vscode-insiders-shared/sharedStorage" },
        { "path": "$HOME/.vscode-insiders-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage/state.vscdb" },
        { "path": "$HOME/.vscodium-shared/sharedStorage" },
        { "path": "$HOME/.vscodium-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/VSCodium/User/globalStorage" },
        { "path": "$CONFIG/VSCodium/User/globalStorage/state.vscdb" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "**" },
        { "path": "$HOME/.vscode-shared/sharedStorage" },
        { "path": "$HOME/.vscode-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/Code/User/globalStorage" },
        { "path": "$CONFIG/Code/User/globalStorage/state.vscdb" },
        { "path": "$HOME/.vscode-insiders-shared/sharedStorage" },
        { "path": "$HOME/.vscode-insiders-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage/state.vscdb" },
        { "path": "$HOME/.vscodium-shared/sharedStorage" },
        { "path": "$HOME/.vscodium-shared/sharedStorage/state.vscdb" },
        { "path": "$CONFIG/VSCodium/User/globalStorage" },
        { "path": "$CONFIG/VSCodium/User/globalStorage/state.vscdb" }
      ]
    },
    "log:default"
  ]
}
