{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Capabilities for the app window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "vscode-cli-win-v",
          "cmd": "code.cmd",
          "args": ["-v"]
        },
        {
          "name": "vscode-cli-win-folder",
          "cmd": "code.cmd",
          "args": [
            "--",
            { "validator": ".+" }
          ]
        },
        {
          "name": "vscode-cli-mac-path-v",
          "cmd": "code",
          "args": ["-v"]
        },
        {
          "name": "vscode-cli-mac-path-folder",
          "cmd": "code",
          "args": [
            "--",
            { "validator": ".+" }
          ]
        }
      ]
    },
    "os:allow-family",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-locale",
    "notification:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$CONFIG/Code/User/globalStorage" },
        { "path": "$CONFIG/Code/User/globalStorage/state.vscdb" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage" },
        { "path": "$CONFIG/Code - Insiders/User/globalStorage/state.vscdb" },
        { "path": "$CONFIG/VSCodium/User/globalStorage" },
        { "path": "$CONFIG/VSCodium/User/globalStorage/state.vscdb" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "log:default"
  ]
}
