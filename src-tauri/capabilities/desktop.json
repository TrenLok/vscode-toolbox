{
  "identifier": "desktop-capability",
  "windows": [
    "main"
  ],
  "permissions": [
    "autostart:default",
    "updater:default",
    "process:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "**"
        }
      ]
    }
  ]
}
