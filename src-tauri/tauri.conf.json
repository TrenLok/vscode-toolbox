{
	"$schema": "https://schema.tauri.app/config/2",
	"bundle": {
    "createUpdaterArtifacts": true,
		"active": true,
		"targets": ["nsis"],
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"timestampUrl": ""
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": [],
		"externalBin": [],
		"copyright": "",
