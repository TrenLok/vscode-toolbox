	"build": {
		"beforeBuildCommand": "pnpm run generate",
		"frontendDist": "../dist",
		"beforeDevCommand": "pnpm run dev",
		"devUrl": "http://localhost:3000"
	},
	"productName": "VSCode Toolbox",
	"version": "1.0.0",
	"identifier": "com.trenlok.vscode-toolbox",
	"plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQjBCQ0FCOERCRURGMDgKUldRSTM3Nk5xN3l3U3JnRStDdFpJY09SQy9TUFpqMXJWM3ExODFnNWtwdHE4UnpTRHVGcDZxOWQK",
