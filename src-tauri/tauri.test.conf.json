{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "createUpdaterArtifacts": false,
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "",
    "longDescription": ""
  },
  "build": {
    "beforeBuildCommand": "pnpm run generate",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:3000"
  },
  "productName": "VSCode Toolbox Test",
  "version": "1.5.0-test",
  "identifier": "com.trenlok.vscode-toolbox.test",
  "app": {
    "windows": [
      {
        "title": "VSCode Toolbox Test",
        "width": 460,
        "height": 698,
        "minWidth": 460,
        "minHeight": 698,
        "resizable": false,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "hiddenTitle": true,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "shadow": true,
        "focusable": true,
        "visible": false,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  }
}
